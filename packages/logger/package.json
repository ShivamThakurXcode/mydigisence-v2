{
  "name": "@mydigisence/logger",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist",
    "dev": "tsup src/index.ts --format esm,cjs --dts --out-dir dist --watch",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@mydigisence/configs": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
