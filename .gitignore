# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Environment files — NEVER commit secrets
.env
.env.local
.env.*.local
services/**/.env
apps/**/.env.local

# Turborepo
.turbo/

# TypeScript
*.tsbuildinfo

# Compiled output sitting next to source (tsc artifacts inside src/)
# These duplicate Next.js pages and cause "Duplicate page detected" errors
apps/web-platform/src/**/*.js
apps/web-platform/src/**/*.js.map
apps/web-platform/src/**/*.d.ts
apps/web-platform/src/**/*.d.ts.map
apps/web-platform/next.config.js
apps/web-platform/next.config.js.map
apps/web-platform/middleware.js
apps/web-platform/middleware.js.map
apps/web-platform/tailwind.config.js
apps/web-platform/tailwind.config.js.map

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo

# Prisma
packages/database/node_modules/.prisma/

# Next.js
apps/web-platform/.next/
apps/*/out/

# Docker volumes (don't track local compose state)
infrastructure/docker/volumes/
