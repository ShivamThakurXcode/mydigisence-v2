# ============================================================
# MYDIGISENCE — ENVIRONMENT VARIABLES REFERENCE
# Copy this file to .env.local (apps) or .env (services)
# NEVER commit actual secrets
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=mongodb://admin:devpassword@localhost:27017/mydigisence?authSource=admin

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-256-bit-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (MailHog for dev) ─────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@mydigisence.com
FROM_NAME=MyDigiSence

# ─── OAuth ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Stripe (Payments) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Cloudflare R2 (File Storage) ───────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mydigisence-media
R2_PUBLIC_URL=https://media.mydigisence.com

# ─── AI ──────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Search ──────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── Vector DB ───────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Analytics DB ────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123

# ─── Error Tracking ──────────────────────────────────────────
SENTRY_DSN=

# ─── Service Ports ───────────────────────────────────────────
GATEWAY_SERVICE_PORT=4000
AUTH_SERVICE_PORT=4001
USER_SERVICE_PORT=4002
PROFILE_SERVICE_PORT=4003
MARKETPLACE_SERVICE_PORT=4004
BOOKING_SERVICE_PORT=4005
SEARCH_SERVICE_PORT=4006
PAYMENT_SERVICE_PORT=4007
NOTIFICATION_SERVICE_PORT=4008
EMAIL_SERVICE_PORT=4009
QUEUE_SERVICE_PORT=4010
MEDIA_SERVICE_PORT=4011
CRM_SERVICE_PORT=4012
AI_SERVICE_PORT=4013
AUTOMATION_SERVICE_PORT=4014
WEBSOCKET_SERVICE_PORT=4015
ANALYTICS_SERVICE_PORT=4016
MODERATION_SERVICE_PORT=4017

# ─── Internal Service URLs (used by gateway) ─────────────────
AUTH_SERVICE_URL=http://localhost:4001
USER_SERVICE_URL=http://localhost:4002
PROFILE_SERVICE_URL=http://localhost:4003
MARKETPLACE_SERVICE_URL=http://localhost:4004
BOOKING_SERVICE_URL=http://localhost:4005
SEARCH_SERVICE_URL=http://localhost:4006
PAYMENT_SERVICE_URL=http://localhost:4007
NOTIFICATION_SERVICE_URL=http://localhost:4008
EMAIL_SERVICE_URL=http://localhost:4009
MEDIA_SERVICE_URL=http://localhost:4011
CRM_SERVICE_URL=http://localhost:4012
AI_SERVICE_URL=http://localhost:4013
AUTOMATION_SERVICE_URL=http://localhost:4014
WEBSOCKET_SERVICE_URL=http://localhost:4015
ANALYTICS_SERVICE_URL=http://localhost:4016

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
